# NBA DFS Optimizer - Environment Configuration Example
# Copy this file to .env and update the paths to match your local setup

# Path to the DKEntries.csv template downloaded from DraftKings
NBA_ENTRIES_PATH=/path/to/downloads/DKEntries.csv

# Directory where your projection CSV files (NBA-Projs-*.csv) are stored
NBA_PROJS_DIR=/path/to/projections

# Directory where intermediate lineup pools and ranked lineups will be stored
NBA_LINEUP_DIR=/path/to/lineup-exports

# Directory where the final upload-ready CSVs will be saved
NBA_OUTPUT_DIR=/path/to/downloads