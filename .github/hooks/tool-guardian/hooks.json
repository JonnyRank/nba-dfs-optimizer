{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "hooks/tool-guardian/guard-tool.sh",
        "cwd": ".",
        "env": {
          "GUARD_MODE": "warn",
          "SKIP_TOOL_GUARD": "true"
        },
        "timeoutSec": 10
      }
    ]
  }
}
